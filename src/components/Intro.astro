---
import profilePicture from "../assets/pfp360.jpg";

interface Props {
  name: string;
  subtitle: string;
}

const { name, subtitle } = Astro.props;
---

<section class="intro">
  <div class="content">
      <img src={profilePicture.src} alt="A close up head shot of Ethan, an implausibly handsome young man (if you are to believe his mother)" class="pfp" fetchpriority="high" />
    <div class="text">
      <h1 class="typing">Hi, I'm {name}</h1>
      <p class="subtitle">{subtitle}</p>
    </div>
  </div>
</section>

<style>
  .intro {
    padding: 8rem 2rem 6rem;
    display: flex;
    justify-content: center;
  }

  .content {
    max-width: 600px;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .pfp {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    border: 3px solid var(--ctp-lavender);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }

  .pfp:hover {
    transform: scale(1.05);
    border-color: var(--ctp-pink);
  }

  .text {
    flex: 1;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    color: var(--ctp-text);
    margin-bottom: 0.5rem;
  }

  h1.typing {
    overflow: hidden;
    white-space: nowrap;
    width: 0;
  }

  @keyframes typing {
    to { width: var(--typing-width); }
  }

  .subtitle {
    font-size: 1rem;
    color: var(--ctp-subtext0);
    opacity: 0.8;
  }

  @media (max-width: 600px) {
    .intro {
      padding: 4rem 2rem 3rem;
    }

    .content {
      flex-direction: column;
      text-align: center;
    }

    .pfp {
      width: 180px;
      height: 180px;
    }

    h1 {
      font-size: 1.5rem;
    }

    h1.typing {
      margin-inline: auto;
    }
  }
</style>

<script>
  const h1 = document.querySelector("h1.typing") as HTMLElement;
  if (h1) {
    const len = h1.textContent!.length;
    const duration = Math.max(0.8, len * 0.07);
    h1.style.setProperty("--typing-width", `${len}ch`);
    h1.style.animation = `typing ${duration}s steps(${len}, end) forwards`;
  }
</script>
