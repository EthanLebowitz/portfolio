---
import profilePicture from "../assets/pfp360.jpg";

interface Props {
  name: string;
  subtitle: string;
}

const { name, subtitle } = Astro.props;
---

<section class="intro">
  <div class="content">
      <div class="pfp-wrapper">
        <img src={profilePicture.src} alt="A close up head shot of Ethan, an implausibly handsome young man (if you are to believe his mother)" class="pfp" fetchpriority="high" />
        <svg class="pfp-border" viewBox="0 0 186 186" xmlns="http://www.w3.org/2000/svg">
          <circle cx="93" cy="93" r="90" />
        </svg>
      </div>
    <div class="text">
      <h1 class="typing">Hi, I'm {name}</h1>
      <p class="subtitle" data-animate>{subtitle}</p>
    </div>
  </div>
</section>

<style>
  .intro {
    padding: 8rem 2rem 6rem;
    display: flex;
    justify-content: center;
  }

  .content {
    max-width: 600px;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .pfp-wrapper {
    position: relative;
    width: 186px;
    height: 186px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .pfp-wrapper:hover {
    transform: scale(1.05);
  }

  .pfp-wrapper:hover .pfp-border circle {
    stroke: var(--ctp-pink);
  }

  .pfp {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .pfp.visible {
    opacity: 1;
  }

  .pfp-border {
    position: absolute;
    inset: 0;
    width: 186px;
    height: 186px;
    pointer-events: none;
  }

  @keyframes pfp-border-draw {
    from {
      stroke-dasharray: 0 565.49;
      stroke-dashoffset: 0;
    }
    to {
      stroke-dasharray: 565.49 0;
      stroke-dashoffset: -141.37;
    }
  }

  .pfp-border circle {
    fill: none;
    stroke: var(--ctp-lavender);
    stroke-width: 3;
    stroke-dasharray: 0 565.49;
    stroke-dashoffset: 0;
    transform-box: fill-box;
    transform-origin: center;
    transform: rotate(-90deg);
    transition: stroke 0.3s ease;
  }

  .pfp-border circle.visible {
    animation: pfp-border-draw 0.8s ease-out forwards;
  }

  .text {
    flex: 1;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    color: var(--ctp-text);
    margin-bottom: 0.5rem;
  }

  h1.typing {
    overflow: hidden;
    white-space: nowrap;
    width: 0;
  }

  @keyframes typing {
    to { width: var(--typing-width); }
  }

  .subtitle {
    font-size: 1rem;
    color: var(--ctp-subtext0);
  }

  .subtitle.visible {
    opacity: 0.8 !important;
  }

  @media (max-width: 600px) {
    .intro {
      padding: 4rem 2rem 3rem;
    }

    .content {
      flex-direction: column;
      text-align: center;
    }

    h1 {
      font-size: 1.5rem;
    }

    h1.typing {
      margin-inline: auto;
    }
  }
</style>

<script>
  const h1 = document.querySelector("h1.typing") as HTMLElement;
  if (h1) {
    const len = h1.textContent!.length;
    const duration = Math.max(0.8, len * 0.07);
    h1.style.setProperty("--typing-width", `${len}ch`);
    h1.style.animation = `typing ${duration}s steps(${len}, end) forwards`;
    h1.addEventListener("animationend", () => {
      document.dispatchEvent(new CustomEvent("typing-done"));
    });
  }

  document.querySelector(".pfp")?.classList.add("visible");
  document.querySelector(".pfp-border circle")?.classList.add("visible");
</script>
