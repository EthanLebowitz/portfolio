---
import profilePicture from "../assets/pfp360.jpg";

interface Props {
  name: string;
  subtitle: string;
}

const { name, subtitle } = Astro.props;
---

<section class="intro">
  <div class="content">
      <div class="pfp-wrapper">
        <img src={profilePicture.src} alt="A close up head shot of Ethan, an implausibly handsome young man (if you are to believe his mother)" class="pfp" fetchpriority="high" />
        <svg class="pfp-border" viewBox="0 0 186 186" xmlns="http://www.w3.org/2000/svg"></svg>
      </div>
    <div class="text">
      <h1 class="typing">Hi, I'm {name}</h1>
      <p class="subtitle" data-animate>{subtitle}</p>
    </div>
  </div>
</section>

<style>
  .intro {
    padding: 8rem 2rem 6rem;
    display: flex;
    justify-content: center;
  }

  .content {
    max-width: 600px;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .pfp-wrapper {
    position: relative;
    width: 186px;
    height: 186px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .pfp-wrapper:hover {
    transform: scale(1.05);
  }

  .pfp-wrapper:hover .pfp-border :global(circle) {
    stroke: var(--ctp-pink);
  }

  .pfp {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .pfp.visible {
    opacity: 1;
  }

  .pfp-border {
    position: absolute;
    inset: 0;
    width: 186px;
    height: 186px;
    pointer-events: none;
  }

  .pfp-border :global(circle) {
    fill: none;
    stroke: var(--ctp-lavender);
    stroke-width: 3;
    transform-box: fill-box;
    transform-origin: center;
    transform: rotate(-90deg);
    transition: stroke 0.3s ease;
  }

  .text {
    flex: 1;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    color: var(--ctp-text);
    margin-bottom: 0.5rem;
  }

  h1.typing {
    overflow: hidden;
    white-space: nowrap;
    width: 0;
  }

  @keyframes typing {
    to { width: var(--typing-width); }
  }

  .subtitle {
    font-size: 1rem;
    color: var(--ctp-subtext0);
  }

  .subtitle.visible {
    opacity: 0.8 !important;
  }

  @media (max-width: 600px) {
    .intro {
      padding: 4rem 2rem 3rem;
    }

    .content {
      flex-direction: column;
      text-align: center;
    }

    h1 {
      font-size: 1.5rem;
    }

    h1.typing {
      margin-inline: auto;
    }
  }
</style>

<script>
  const h1 = document.querySelector("h1.typing") as HTMLElement;
  if (h1) {
    const len = h1.textContent!.length;
    const duration = Math.max(0.8, len * 0.07);
    h1.style.setProperty("--typing-width", `${len}ch`);
    h1.style.animation = `typing ${duration}s steps(${len}, end) forwards`;
    h1.addEventListener("animationend", () => {
      document.dispatchEvent(new CustomEvent("typing-done"));
    });
  }

  // --- pfp border animation ---
  const NUM_POINTS = 3; // easy to change

  const C = 2 * Math.PI * 90;
  const svg = document.querySelector(".pfp-border");

  document.querySelector(".pfp")?.classList.add("visible");

  if (svg) {
    // Distribute points evenly with random jitter (guarantees minimum spacing)
    const baseSpacing = C / NUM_POINTS;
    const maxJitter = baseSpacing / 2;
    const positions = Array.from({ length: NUM_POINTS }, (_, i) => {
      const base = (i / NUM_POINTS) * C;
      const jitter = (Math.random() * 2 - 1) * maxJitter;
      return (base + jitter + C) % C;
    }).sort((a, b) => a - b);

    positions.forEach((pos, i) => {
      const prev = positions[(i - 1 + NUM_POINTS) % NUM_POINTS];
      const next = positions[(i + 1) % NUM_POINTS];

      // Clockwise arc distances to neighbours
      const dPrev = (pos - prev + C) % C;
      const dNext = (next - pos + C) % C;

      // This segment spans from the midpoint with prev to the midpoint with next
      const segLen = (dPrev + dNext) / 2;

      // Trailing edge backs up dPrev/2 counter-clockwise from pos;
      // adding dPrev/2 to dashoffset (instead of subtracting from pos) keeps
      // the interpolation on the short path even when the segment wraps 0°.
      const startDashoffset = -pos;
      const endDashoffset = -pos + dPrev / 2;

      const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
      circle.setAttribute("cx", "93");
      circle.setAttribute("cy", "93");
      circle.setAttribute("r", "90");
      svg.appendChild(circle);

      circle.animate(
        [
          { strokeDasharray: `0 ${C}`, strokeDashoffset: startDashoffset },
          { strokeDasharray: `${segLen} ${C - segLen}`, strokeDashoffset: endDashoffset },
        ],
        { duration: 500, easing: "ease-out", fill: "forwards" }
      );
    });
  }
</script>
