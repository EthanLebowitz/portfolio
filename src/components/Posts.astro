---
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts", ({ data }) => {
  return data.draft !== true;
});

// Sort posts by date (newest first)
const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
};
---

<section class="posts">
  <div class="content">
    <h2 class="section-title">Blog Posts</h2>
    <div class="posts-list">
      {
        posts.length === 0 ? (
          <p class="no-posts">No posts yet. Check back soon!</p>
        ) : (
          posts.map((post) => (
            <a
              href={`/posts/${post.slug}`}
              class="post-link"
              style="--post-color: var(--ctp-mauve)"
            >
              <div class="post-content">
                <div class="post-header">
                  <h3 class="post-title">{post.data.title}</h3>
                  <time class="post-date" datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                </div>
                <p class="post-description">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="post-tags">
                    {post.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))
        )
      }
    </div>
  </div>
</section>

<style>
  .posts {
    padding: 4rem 2rem;
    background: var(--ctp-base);
  }

  .content {
    max-width: 600px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--ctp-text);
    margin-bottom: 2rem;
    text-align: center;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .no-posts {
    text-align: center;
    color: var(--ctp-subtext0);
    font-size: 1.1rem;
    padding: 2rem;
  }

  .post-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 2rem;
    background-color: var(--ctp-surface0);
    border: 2px solid var(--post-color);
    border-radius: 12px;
    text-decoration: none;
    color: var(--ctp-text);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .post-link::before {
    content: "";
    position: absolute;
    inset: -1px;
    background-color: var(--post-color);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }

  .post-link:hover::before {
    transform: scaleX(1);
  }

  .post-link:hover {
    transform: translateX(8px);
  }

  .post-content {
    flex: 1;
    z-index: 1;
  }

  .post-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--post-color);
    margin: 0;
    transition: color 0.3s ease;
  }

  .post-link:hover .post-title {
    color: var(--ctp-base);
  }

  .post-date {
    font-size: 0.9rem;
    color: var(--ctp-subtext0);
    white-space: nowrap;
    transition: color 0.3s ease;
  }

  .post-link:hover .post-date {
    color: var(--ctp-base);
  }

  .post-description {
    color: var(--ctp-text);
    line-height: 1.6;
    margin: 0 0 1rem 0;
    transition: color 0.3s ease;
  }

  .post-link:hover .post-description {
    color: var(--ctp-base);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: var(--ctp-surface1);
    color: var(--post-color);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .post-link:hover .tag {
    background: var(--ctp-base);
    color: var(--post-color);
  }

  .post-link:hover {
    color: var(--ctp-base);
  }

  @media (max-width: 768px) {
    .posts {
      padding: 3rem 1rem;
    }

    .section-title {
      font-size: 2rem;
    }

    .post-title {
      font-size: 1.25rem;
    }

    .post-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
